.page {
  min-height: 100vh;
  padding: 40rpx 28rpx;
  background: #f6f3ed;
  box-sizing: border-box;
}

.header {
  margin-bottom: 28rpx;
}

.title {
  color: #1f2933;
  font-size: 44rpx;
  font-weight: 700;
}

.subtitle {
  margin-top: 8rpx;
  color: #65717c;
  font-size: 26rpx;
}

.tool-card {
  padding: 28rpx;
  background: #fffdf8;
  border: 1rpx solid #d8d2c8;
  border-radius: 8rpx;
}

.tool-title {
  color: #1f2933;
  font-size: 34rpx;
  font-weight: 600;
}

.tool-desc {
  margin-top: 10rpx;
  color: #65717c;
  font-size: 26rpx;
}
