.page {
  padding: 24rpx;
  background: #faf4e8;
}

.header {
  margin-bottom: 24rpx;
  text-align: center;
}

.month {
  display: inline-block;
  width: 300rpx;
  font-size: 36rpx;
  font-weight: 600;
  text-align: center;
}

.subtitle {
  margin-top: 6rpx;
  color: #26362b;
  font-size: 34rpx;
  font-weight: 600;
}

.guide {
  margin-bottom: 18rpx;
  padding: 16rpx 20rpx;
  color: #4f6f43;
  background: #eef6e8;
  border: 1rpx solid #c8d9bc;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.base-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.field {
  display: block;
  padding: 16rpx;
  background: #fffaf0;
  border: 1rpx solid #d7c9b1;
  border-radius: 8rpx;
}

.field text {
  display: block;
  margin-bottom: 8rpx;
  color: #70806d;
  font-size: 24rpx;
}

.table-scroll {
  background: #fffaf0;
  border: 1rpx solid #c5b79d;
}

.table {
  width: 1440rpx;
}

.tr {
  display: grid;
  grid-template-columns: 160rpx repeat(8, 160rpx);
  height: 76rpx;
}

.cell {
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 0;
  padding: 16rpx 10rpx;
  border-right: 1rpx solid #c5b79d;
  border-bottom: 1rpx solid #c5b79d;
  text-align: center;
  font-size: 26rpx;
  line-height: 1.2;
  overflow: hidden;
}

.th {
  font-weight: 600;
  background: #efe4d0;
}

.editable {
  background: #eef6e8;
  box-shadow: inset 0 0 0 2rpx #b9d1ad;
}

.editable-input {
  color: #26362b;
  background: #eef6e8;
  border-radius: 6rpx;
}

.cell-input {
  width: 100%;
  height: 44rpx;
  min-height: 44rpx;
  padding: 0;
  background: transparent;
  text-align: center;
  font-size: 26rpx;
  line-height: 44rpx;
}

.cell-switch {
  transform: scale(0.68);
}

.errors {
  margin-top: 18rpx;
  color: #a23b2a;
  font-size: 24rpx;
}

.summary {
  display: grid;
  gap: 8rpx;
  margin-top: 18rpx;
  color: #26362b;
  font-size: 28rpx;
}

.actions {
  display: flex;
  gap: 16rpx;
  margin-top: 22rpx;
}

.actions button {
  flex: 1;
  margin: 0;
  font-size: 28rpx;
}

.actions button[type="primary"] {
  background: #6f965f;
}

.bill-canvas {
  width: 1px;
  height: 1px;
  margin-top: -1px;
  overflow: hidden;
  pointer-events: none;
}

.preview {
  display: block;
  width: 100%;
  margin-top: 24rpx;
  border: 1rpx solid #d7c9b1;
}
