.page {
  min-height: 100vh;
  padding: 20rpx;
  background: #faf4e8;
  box-sizing: border-box;
}

.toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.title {
  color: #26362b;
  font-size: 34rpx;
  font-weight: 700;
}

.hint {
  margin-top: 4rpx;
  color: #70806d;
  font-size: 22rpx;
}

.toolbar button {
  width: 160rpx;
  margin: 0;
  background: #6f965f;
  font-size: 26rpx;
}

.base-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-bottom: 14rpx;
}

.field {
  display: block;
  padding: 12rpx;
  background: #fffaf0;
  border: 1rpx solid #d7c9b1;
  border-radius: 8rpx;
}

.field text {
  display: block;
  margin-bottom: 6rpx;
  color: #70806d;
  font-size: 22rpx;
}

.table {
  width: 100%;
  background: #fffaf0;
  border-top: 1rpx solid #c5b79d;
  border-left: 1rpx solid #c5b79d;
}

.tr {
  display: grid;
  grid-template-columns: 120rpx repeat(8, 1fr);
  height: 60rpx;
}

.cell {
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 0;
  padding: 8rpx;
  border-right: 1rpx solid #c5b79d;
  border-bottom: 1rpx solid #c5b79d;
  text-align: center;
  font-size: 22rpx;
  overflow: hidden;
}

.th {
  font-weight: 600;
  background: #efe4d0;
}

.editable {
  background: #eef6e8;
  box-shadow: inset 0 0 0 2rpx #b9d1ad;
}

.invalid {
  background: #fff1ed;
  border-color: #d65b45;
  box-shadow: inset 0 0 0 3rpx #d65b45;
}

.editable-input {
  color: #26362b;
  background: #eef6e8;
  border-radius: 6rpx;
}

.cell-input {
  width: 100%;
  height: 36rpx;
  min-height: 36rpx;
  padding: 0;
  background: transparent;
  text-align: center;
  font-size: 22rpx;
  line-height: 36rpx;
}

.cell-switch {
  transform: scale(0.6);
}

.errors {
  margin-top: 12rpx;
  color: #a23b2a;
  font-size: 22rpx;
}
